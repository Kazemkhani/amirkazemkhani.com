# amirkazemkhani.com — Conversion Infrastructure Stack
# Paste these into Vercel → Project Settings → Environment Variables.
# All are client-exposed by virtue of the VITE_ prefix; do NOT add server-side
# secrets here.

# ── HubSpot Free CRM (lead capture) ───────────────────────────────────────────
# Source: HubSpot → Settings → Account Setup → Account Defaults → Hub ID.
VITE_HUBSPOT_PORTAL_ID=
# Source: HubSpot → Forms → "Discovery Call Lead" → Embed → form GUID.
VITE_HUBSPOT_DISCOVERY_FORM_ID=
# Source: HubSpot → Forms → "NOVA Signal Newsletter" → Embed → form GUID.
VITE_HUBSPOT_NEWSLETTER_FORM_ID=

# ── Cal.com (booking) ─────────────────────────────────────────────────────────
# Source: Cal.com → Event Types → "30-min Discovery Call" → public URL.
# Default fallback in code: https://cal.com/amirkazemkhani/discovery
VITE_CAL_URL=https://cal.com/amirkazemkhani/discovery

# ── LinkedIn Insight Tag (optional, retargeting) ─────────────────────────────
# Source: LinkedIn Campaign Manager → Account Assets → Insight Tag → Partner ID.
# Leave blank to skip the pixel entirely (and skip the cookie banner — Plausible
# alone doesn't need consent).
VITE_LINKEDIN_PARTNER_ID=

# ── Plausible Analytics ──────────────────────────────────────────────────────
# No env var needed — the script is hard-coded to amirkazemkhani.com as the
# site identifier in client/src/lib/analytics.ts. Localhost + *.vercel.app are
# auto-skipped to keep stats clean.
